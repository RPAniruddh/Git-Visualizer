<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- DTO records intentionally carry Jackson JsonNode references; they are read-only
         response payloads serialized immediately, so exposing internal representation
         is not a defect here. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
